# =============================================================================
# FHIR Structuring Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys

# -----------------------------------------------------------------------------
# Required API Keys
# -----------------------------------------------------------------------------

# Google Gemini API Key (Required)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# -----------------------------------------------------------------------------
# Optional API Keys
# -----------------------------------------------------------------------------

# Anthropic Claude API Key (Optional - for multi-agent validation)
# Get your key from: https://console.anthropic.com/
# If not provided, will use Python-only validation without LLM feedback
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# Model Configuration (Optional - defaults provided)
# -----------------------------------------------------------------------------

# Gemini model to use for extraction
# GEMINI_MODEL_NAME=gemini-3-flash-preview

# Claude model to use for validation
# CLAUDE_MODEL_NAME=claude-sonnet-4-6

# Maximum retries for validation loop
# MAX_VALIDATION_RETRIES=3

# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Advanced Configuration (Optional)
# -----------------------------------------------------------------------------

# NCI Terminology API base URL
# NCI_API_BASE_URL=https://api-evsrest.nci.nih.gov/api/v1

# FHIR Specification base URL
# FHIR_SPEC_BASE_URL=https://hl7.org/fhir/R4/

# Directory for cached FHIR documentation
# FHIR_DOCS_DIR=data/fhir_docs

# Directory for agent prompts
# PROMPTS_DIR=prompts

# Default terminology system
# DEFAULT_TERMINOLOGY=snomedct_us

# HTTP retry configuration
# HTTP_RETRY_ATTEMPTS=3
# HTTP_RETRY_MIN_WAIT=2
# HTTP_RETRY_MAX_WAIT=10
