# =============================================================================
# FHIR Structuring Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys

# -----------------------------------------------------------------------------
# Required API Keys
# -----------------------------------------------------------------------------

# OpenAI API Key (Required for validation agent, optional for extraction)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude API Key (Required for extraction agent, optional for validation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# Optional API Keys
# -----------------------------------------------------------------------------

# Google Gemini API Key (Alternative extraction model)
# Get your key from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your-google-api-key-here

# -----------------------------------------------------------------------------
# Model Configuration (Optional - defaults provided)
# -----------------------------------------------------------------------------

# Which provider to use for extraction agent (default: anthropic)
# Options: "anthropic" (recommended), "openai", "google"
# EXTRACTION_MODEL_PROVIDER=anthropic

# Which provider to use for validation agent (default: openai)
# Options: "openai" (recommended), "anthropic"
# VALIDATION_MODEL_PROVIDER=openai

# Claude model for extraction (default: claude-sonnet-4-6)
# Used when EXTRACTION_MODEL_PROVIDER=anthropic or VALIDATION_MODEL_PROVIDER=anthropic
# CLAUDE_MODEL_NAME=claude-sonnet-4-6

# OpenAI model for extraction (default: gpt-4o)
# Used when EXTRACTION_MODEL_PROVIDER=openai
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo
# OPENAI_MODEL_NAME=gpt-4o

# OpenAI model for validation (default: gpt-5.4)
# Used when VALIDATION_MODEL_PROVIDER=openai
# Options: gpt-5.4, gpt-5.4-mini, gpt-5.4-nano, gpt-4o
# OPENAI_VALIDATOR_MODEL_NAME=gpt-5.4

# Gemini model for extraction (default: gemini-3-flash-preview)
# Used when EXTRACTION_MODEL_PROVIDER=google
# GEMINI_MODEL_NAME=gemini-3-flash-preview

# Maximum retries for validation loop
# MAX_VALIDATION_RETRIES=3

# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Advanced Configuration (Optional)
# -----------------------------------------------------------------------------

# NCI Terminology API base URL
# NCI_API_BASE_URL=https://api-evsrest.nci.nih.gov/api/v1

# FHIR Specification base URL
# FHIR_SPEC_BASE_URL=https://hl7.org/fhir/R4/

# Directory for cached FHIR documentation
# FHIR_DOCS_DIR=data/fhir_docs

# Directory for agent prompts
# PROMPTS_DIR=prompts

# Default terminology system
# DEFAULT_TERMINOLOGY=snomedct_us

# HTTP retry configuration
# HTTP_RETRY_ATTEMPTS=3
# HTTP_RETRY_MIN_WAIT=2
# HTTP_RETRY_MAX_WAIT=10
